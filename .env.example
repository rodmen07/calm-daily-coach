# Firebase client config for Google login
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Optional: select check-in persistence backend.
# Values: local (default), firestore
NEXT_PUBLIC_CHECKIN_BACKEND=local

# Optional: Stripe Payment Link URL for the $5/month membership
# (e.g. https://buy.stripe.com/xxxx). When unset, the pricing CTA
# falls back to the early-access mailto flow.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
